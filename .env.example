# --- VLM / LLM provider ---
# Supported: "bedrock" (default), "openai", or "anthropic".
VLM_PROVIDER=bedrock
LLM_PROVIDER=bedrock

# Bedrock model IDs (cross-region inference profile recommended).
VLM_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
LLM_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# --- AWS / Bedrock auth ---
AWS_REGION=us-east-1
# Cohere Rerank 3.5 is not available in us-east-2; use us-east-1 or us-west-2.
# Easiest: paste a short-lived Bedrock API key here. boto3 picks it up automatically.
# AWS_BEARER_TOKEN_BEDROCK=
# Or use standard AWS credentials (aws configure, AWS_ACCESS_KEY_ID/SECRET, SSO, etc.).

# --- Optional cloud providers ---
# Only needed if you switch VLM_PROVIDER / LLM_PROVIDER to "openai" or "anthropic".
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Bedrock embedding / reranking ---
# Titan works in us-east-1; many regions (e.g. us-east-2) need Cohere Embed v4 instead:
#   EMBEDDING_MODEL=us.cohere.embed-v4:0
EMBEDDING_MODEL=amazon.titan-embed-image-v1
EMBEDDING_DIM=1024
RERANKER_MODEL=cohere.rerank-v3-5:0

# --- Storage paths (relative to project root unless absolute) ---
DATA_DIR=./data
CHROMA_DIR=./data/chroma
SQLITE_PATH=./data/imagecb.db
IMAGE_CACHE_DIR=./data/images
UPLOADS_DIR=./data/uploads
BM25_PATH=./data/bm25.pkl

# --- Ingest performance ---
INGEST_WORKERS=4
INGEST_MAX_IMAGE_SIDE=1024
INGEST_BATCH_UPSERT=16
# CLI file batching (0 = single run; 25 recommended for large corpora)
# INGEST_BATCH_SIZE=25
# INGEST_IMAGE_TIMEOUT_SEC=300
# BEDROCK_MAX_CONCURRENT=2
# BEDROCK_READ_TIMEOUT=120
# BEDROCK_CONNECT_TIMEOUT=10
# BEDROCK_MAX_RETRIES=6

# --- Post-ingest index repair ---
# Automatically fix missing cached PNGs, failed captions, and missing Chroma vectors.
POST_INGEST_REPAIR_ENABLED=true
POST_INGEST_REPAIR_INCLUDE_WEAK=false
POST_INGEST_REPAIR_REINDEX_VECTORS=true

# --- OCR ---
# Path to the Tesseract binary. Leave empty if it is on PATH.
# TESSERACT_CMD=   # e.g. C:\Program Files\Tesseract-OCR\tesseract.exe on Windows

# --- Deck suggest (slide-aware image suggestions) ---
DECK_CACHE_DIR=./data/deck_cache
DECK_LLM_BATCH_SIZE=10
DECK_MAX_SLIDES=200
DECK_MAX_CHARS_PER_SLIDE=6000
DECK_MAX_UPLOAD_BYTES=52428800
DECK_CACHE_ENABLED=true

# --- Admin / telemetry ---
# Required for /api/admin/* and POST /api/ingest. Use a long random secret.
ADMIN_API_KEY=
WEAK_RESULT_SCORE_THRESHOLD=0.25
DUPLICATE_SIMILARITY_THRESHOLD=0.95
